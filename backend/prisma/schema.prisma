generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  email             String   @unique
  displayName       String?  @map("display_name")
  avatarUrl         String?  @map("avatar_url")
  isActive          Int      @default(1) @map("is_active")
  isFree            Boolean  @default(true) @map("is_free")
  subscriptionType  String?  @map("subscription_type")
  subscriptionStart DateTime? @map("subscription_start")
  subscriptionEnd   DateTime? @map("subscription_end")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  credential        UserCredential?
  sessions          Session[]
  comments          Comment[]
  favorites         Favorite[]
  whitelists        UserCategoryWhitelist[]
  feedbacks         UserFeedback[]

  @@map("users")
}

model UserCredential {
  userId             String   @id @map("user_id")
  passwordHash       String   @map("password_hash")
  passwordSalt       String   @map("password_salt")
  passwordAlgo       String   @default("pbkdf2-sha256") @map("password_algo")
  lastPasswordChange DateTime? @map("last_password_change")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credentials")
}

model Session {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  refreshTokenHash String   @unique @map("refresh_token_hash")
  userAgent        String?  @map("user_agent")
  ipAddress        String?  @map("ip_address")
  createdAt        DateTime @default(now()) @map("created_at")
  expiresAt        DateTime @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Category {
  id         String        @id @default(cuid())
  key        String        @unique
  name       String
  isActive   Int           @default(1) @map("is_active")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  content    ContentItem[] @relation("CategoryContent")
  whitelists UserCategoryWhitelist[] @relation("CategoryWhitelist")

  @@map("categories")
}

model ContentItem {
  id          String        @id @default(cuid())
  categoryId  String        @map("category_id")
  providerKey String        @map("provider_key")
  sourceId    String        @map("source_id")

  isActive    Int           @default(1) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  category    Category      @relation("CategoryContent", fields: [categoryId], references: [id], onDelete: Cascade)
  units       ContentUnit[]
  comments    Comment[]
  favorites   Favorite[]

  @@index([categoryId])
  // @@index([title])
  @@unique([providerKey, sourceId])
  @@map("content_items")
}

model ContentUnit {
  id              String      @id @default(cuid())
  contentItemId   String      @map("content_item_id")
  unitType        String      @map("unit_type") // episode|chapter|movie
  seasonNumber    Int?        @map("season_number")
  unitNumber      Int         @map("unit_number")
  title           String?
  durationSeconds Int?        @map("duration_seconds")
  streamUrl       String?     @map("stream_url")
  publishedAt     DateTime?   @map("published_at")
  contentItem     ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([contentItemId])
  @@unique([contentItemId, unitType, seasonNumber, unitNumber])
  @@map("content_units")
}

model Comment {
  id              String      @id @default(cuid())
  userId          String      @map("user_id")
  contentItemId   String      @map("content_item_id")
  parentCommentId String?     @map("parent_comment_id")
  body            String
  isDeleted       Int         @default(0) @map("is_deleted")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem     ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  parent          Comment?    @relation("CommentChildren", fields: [parentCommentId], references: [id])
  children        Comment[]   @relation("CommentChildren")

  @@index([contentItemId, createdAt])
  @@index([parentCommentId])
  @@map("comments")
}

model Favorite {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  contentItemId String      @map("content_item_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@unique([userId, contentItemId])
  @@map("favorites")
}

model UserCategoryWhitelist {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation("CategoryWhitelist", fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, categoryId])
  @@map("user_category_whitelist")
}

model UserApiToken {
  id        String   @id @default(cuid())
  username  String
  password  String
  hashToken String
  expiresAt DateTime
}

model UserFeedback {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  content     String
  category    String   @default("general") // general, bug, feature, improvement
  rating      Int?     // Optional rating 1-5
  status      String   @default("pending") // pending, in_progress, resolved, rejected
  adminReply  String?  @map("admin_reply")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  resolvedAt  DateTime? @map("resolved_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("user_feedback")
}
