{
  "name": "bun-drama-api",
  "type": "module",
  "scripts": {
    "========================================": "SERVER",
    "dev": "bun --watch server.ts",
    "start": "bun server.ts",
    "========================================= ": "DATABASE",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "=========================================  ": "DEPLOYMENT",
    "deploy:vps": "./scripts/deploy-vps.sh",
    "vps:setup": "./scripts/setup-vps-sqlite.sh",
    "vps:deploy": "bun install && bun run db:generate && bun run db:migrate:prod && ./scripts/deploy-vps.sh",
    "vps:restart": "systemctl restart drama-api.service",
    "vps:logs": "journalctl -u drama-api.service -f",
    "docker:build": "docker build -t drama-api .",
    "docker:run": "docker run -d -p 8787:8787 --env-file .env drama-api",
    "docker:compose": "docker-compose up -d",
    "=========================================   ": "TESTING",
    "test": "bun test src/test",
    "test:rate-limit": "bun test src/test/rate-limit.test.ts",
    "test:functional": "bun test src/test/functional.test.ts",
    "test:integration": "bun test src/test/integration.test.ts",
    "test:watch": "bun test --watch src/test/*.ts",
    "test:coverage": "bun test --coverage src/test/*.ts",
    "test:ci": "bun test src/test/functional-test.ts src/test/integration-test.ts",
    "=========================================    ": "OTHER",
    "predev": "bun run db:generate",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "seed:dummy": "bun scripts/seed-dummy.ts"
  },
  "dependencies": {
    "@consumet/extensions": "^1.8.8",
    "@prisma/client": "^7.3.0",
    "@prisma/config": "^7.3.0",
    "@scalar/hono-api-reference": "^0.9.40",
    "cheerio": "^1.2.0",
    "hono": "^4.11.7",
    "prisma-adapter-bun-sqlite": "^0.8.0",
    "ultrahtml": "^1.6.0",
    "undici": "^7.20.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^25.6.0",
    "prisma": "7.3.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
